{
  "xsappname": "kits-cap-backend-dev",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Admin Scope"
    },
    {
      "name": "$XSAPPNAME.User",
      "description": "User Scope"
    }
  ],
  "role-templates": [
    {
      "name": "AdminRole",
      "description": "Administrator Role",
      "scope-references": [
        "$XSAPPNAME.Admin"
      ]
    },
    {
      "name": "UserRole",
      "description": "Regular User Role",
      "scope-references": [
        "$XSAPPNAME.User"
      ]
    }
  ]
}
